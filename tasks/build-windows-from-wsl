#!/usr/bin/env bash
#MISE description="Build and deploy the Windows logger from WSL."

#USAGE flag "--windows-user <name>" help="Windows username fallback when LOCALAPPDATA detection fails."

set -euo pipefail

detect_local_app_data() {
	if command -v cmd.exe >/dev/null 2>&1 && command -v wslpath >/dev/null 2>&1; then
		local windows_path
		windows_path="$(cmd.exe /C "echo %LOCALAPPDATA%" 2>/dev/null | tr -d '\r' | tail -n 1)"
		if [[ -n "${windows_path}" && "${windows_path}" != "%LOCALAPPDATA%" ]]; then
			wslpath -u "${windows_path}"
			return
		fi
	fi

	local windows_user="${usage_windows_user:-${WINDOWS_USER:-}}"
	if [[ -n "${windows_user}" ]]; then
		printf '/mnt/c/Users/%s/AppData/Local\n' "${windows_user}"
		return
	fi

	echo "Unable to detect Windows LOCALAPPDATA. Pass --windows-user or set WINDOWS_USER." >&2
	exit 1
}

local_app_data="$(detect_local_app_data)"
deploy_dir="${local_app_data}/ChromeCdpResponseLogger/bin"

mise run compile --target windows-x64

mkdir -p "${deploy_dir}"
cp dist/cdp-response-logger-windows-x64.exe "${deploy_dir}/cdp-response-logger.exe"
cp scripts/*.ps1 scripts/*.bat scripts/*.sh "${deploy_dir}/"

echo "Deployed logger and scripts to: ${deploy_dir}"
